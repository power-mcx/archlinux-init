thunar 文件管理器：
1.解锁挂载：
sudo pacman -S thunar-volman gvfs
sudo systemctl enable udisks2.service
2.插件
sudo pacman -S thunar-volman gvfs thunar-archive-plugin file-roller ffmpegthumbnailer tumbler libgsf webp-pixbuf-loader ristretto

安装google字体----解决中文乱码
sudo pacman -S  --needed noto-fonts noto-fonts-cjk noto-fonts-emoji noto-fonts-extra ttf-dejavu ttf-liberation
配置：
cd /etc
sudo nano locale.gen   （去掉 # en_US.UTF-8 UTF-8 以及 zh_CN.UTF-8 UTF-8 前#号后保存）
（如果是需要设置双系统  可以此时将 /etc/default/grub中最后一行提前就设置好 取消掉GRUB_DISABLE_OS_PROBER=false    前面的#号后再保存）
sudo locale-gen
sudoecho  "LANG=zh_CN.UTF-8"  > /etc/locale.conf
reboot

更换jetmono字体：
sudo pacman -S ttf-jetbrains-mono-nerd
sudo fc-cache -fv       检查：fc-list | grep -i "jetbrains mono"
配置：
mkdir -p ~/.config/fontconfig
nano ~/.config/fontconfig/fonts.conf

<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
    <!-- 设置默认无衬线字体为 JetBrains Mono -->
    <match target="pattern">
        <test qual="any" name="family"><string>sans-serif</string></test>
        <edit name="family" mode="assign" binding="same"><string>JetBrains Mono</string></edit>
    </match>

    <!-- 设置默认等宽字体为 JetBrains Mono -->
    <match target="pattern">
        <test qual="any" name="family"><string>monospace</string></test>
        <edit name="family" mode="assign" binding="same"><string>JetBrains Mono</string></edit>
    </match>

    <!-- 设置默认界面字体 -->
    <match target="pattern">
        <test qual="any" name="family"><string>Arial</string></test>
        <edit name="family" mode="assign" binding="same"><string>JetBrains Mono</string></edit>
    </match>

    <!-- 抗锯齿 + 渲染优化 -->
    <match target="font">
        <edit mode="assign" name="antialias"><bool>true</bool></edit>
        <edit mode="assign" name="hinting"><bool>true</bool></edit>
        <edit mode="assign" name="hintstyle"><const>hintslight</const></edit>
        <edit mode="assign" name="rgba"><const>rgb</const></edit>
        <edit mode="assign" name="lcdfilter"><const>lcddefault</const></edit>
    </match>
</fontconfig>

fc-cache -fv


输入法：
sudo pacman -S --needed fcitx5-im fcitx5-chinese-addons fcitx5-pinyin-zhwiki fcitx5-configtool fcitx5-material-color
部分软件无法使用中文输入法：
sudo nano /etc/environment
添加：
GTK_IM_MODULE=fcitx5
QT_IM_MODULE=fcitx5
XMODIFIERS=@im=fcitx5
INPUT_METHOD=fcitx5

重启生效
