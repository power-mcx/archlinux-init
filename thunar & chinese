thunar 文件管理器：
1.解锁挂载：
sudo pacman -S thunar-volman gvfs
sudo systemctl enable udisks2.service
2.插件
sudo pacman -S thunar-volman gvfs thunar-archive-plugin file-roller ffmpegthumbnailer tumbler libgsf webp-pixbuf-loader ristretto

安装google字体----解决中文乱码
sudo pacman -S  --needed noto-fonts noto-fonts-cjk noto-fonts-emoji noto-fonts-extra ttf-dejavu ttf-liberation
配置：
cd /etc
sudo nano locale.gen   （去掉 # en_US.UTF-8 UTF-8 以及 zh_CN.UTF-8 UTF-8 前#号后保存）
（如果是需要设置双系统  可以此时将 /etc/default/grub中最后一行提前就设置好 取消掉GRUB_DISABLE_OS_PROBER=false    前面的#号后再保存）
sudo locale-gen
sudoecho  "LANG=zh_CN.UTF-8"  > /etc/locale.conf
reboot

更换jetmono字体：
sudo pacman -S ttf-jetbrains-mono-nerd
sudo fc-cache -fv       检查：fc-list | grep -i "jetbrains mono"
配置：
#先mkdir 建立文件夹
mkdir   ~/.config/alacritty

#在建立并写入下列数据
sudo nano  ~/.config/alacritty/alacritty.toml

[font]
normal = { family = "JetBrainsMono", style = "Regular" }
bold = { family = "JetBrainsMono", style = "Bold" }
italic = { family = "JetBrainsMono", style = "Italic" }
bold_italic = { family = "JetBrainsMono", style = "Bold Italic" }
size = 13

[general]
import = [
  "~/.config/alacritty/dank-theme.toml"
]

[window]
decorations = "None"
padding = { x = 15, y = 15 }
opacity = 0.9

[scrolling]
history = 3023

[cursor]
style = { shape = "Block", blinking = "On" }
blink_interval = 500unfocused_hollow = true

[mouse]
hide_when_typing = true

[selection]
save_to_clipboard = true

[bell]
duration = 0

[keyboard]
bindings = [
  { key = "C", mods = "Control|Shift", action = "Copy" },
  { key = "V", mods = "Control|Shift", action = "Paste" },
  { key = "N", mods = "Control|Shift", action = "SpawnNewInstance" },
  { key = "Equals", mods = "Control|Shift", action = "IncreaseFontSize" },
  { key = "Minus", mods = "Control", action = "DecreaseFontSize" },
  { key = "Key0", mods = "Control", action = "ResetFontSize" },
  { key = "Enter", mods = "Shift", chars = "\n" },
]

