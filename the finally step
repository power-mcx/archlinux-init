5.校准时间
# 列出可用的亚洲时区
timedatectl list-timezones | grep Shanghai

# 设置为上海时区（中国标准时间 UTC+8）
sudo timedatectl set-timezone Asia/Shanghai

# 确保 NTP 同步开启
sudo timedatectl set-ntp true

# 强制立即同步时间
sudo systemctl restart systemd-timesyncd

